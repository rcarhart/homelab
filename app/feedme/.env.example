FEEDME_PORT=9925
TZ=America/New_York

FEEDME_BASE_URL=https://recipes.rosscarhart.com

ALLOW_SIGNUP=false
ALLOW_PASSWORD_LOGIN=true

# Google OAuth via OIDC
OIDC_AUTH_ENABLED=true
OIDC_SIGNUP_ENABLED=true
OIDC_CONFIGURATION_URL=https://accounts.google.com/.well-known/openid-configuration
OIDC_CLIENT_ID=replace-with-client-id
OIDC_CLIENT_SECRET=replace-with-client-secret
OIDC_PROVIDER_NAME=Google
OIDC_USER_CLAIM=email
OIDC_NAME_CLAIM=name

# AI Provider — Ollama Cloud
FEEDME_OPENAI_BASE_URL=https://api.ollama.com/v1
FEEDME_OPENAI_API_KEY=replace-with-ollama-api-key
FEEDME_OPENAI_MODEL=gemma4:31b
